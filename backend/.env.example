# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL / Aiven / Neon / Supabase)
DATABASE_URL=postgres://[username]:[password]@[host]:[port]/[dbname]?sslmode=require

# Authentication
# Generate a strong random string for this (e.g., using `openssl rand -base64 32`)
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary (For File/Image Attachments)
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Google Gemini (For Agentic AI Features)
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_google_gemini_api_key_here
